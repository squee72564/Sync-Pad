PORT=3001
NODE_ENV=production
LOG_LEVEL=info
DATABASE_URL=postgres://syncpad:replace-me@postgres:5432/syncpad-prod
BETTER_AUTH_SECRET=replace-me-with-at-least-32-random-characters
