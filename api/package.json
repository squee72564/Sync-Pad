{
  "name": "@syncpad/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run --config vitest.config.ts --reporter=agent --silent=passed-only",
    "test:verbose": "vitest run --config vitest.config.ts --reporter=default",
    "test:watch": "vitest --config vitest.config.ts --reporter=default",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:check": "biome check .",
    "lint": "biome check . --write",
    "format:check": "biome format .",
    "format": "biome format . --write",
    "check": "pnpm lint:check && pnpm format:check && pnpm typecheck",
    "auth:generate:dev": "dotenv -e .env -- auth generate --config ./src/lib/auth.ts --output ./src/db/auth-schema.ts",
    "db:generate:dev": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate:dev": "dotenv -e .env -- drizzle-kit migrate"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@hono/node-server": "^2.0.0",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "http-status-codes": "^2.3.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "auth": "^1.6.9",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
