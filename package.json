{
  "name": "syncpad",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test --output-logs=errors-only",
    "test:verbose": "turbo test:verbose --output-logs=full",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "typecheck": "turbo typecheck",
    "lint:check": "turbo lint:check",
    "lint": "turbo lint",
    "check": "turbo check",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "db:generate:dev": "dotenv -e ./api/.env -- pnpm --filter @syncpad/db db:generate:dev",
    "db:migrate:dev": "dotenv -e ./api/.env -- pnpm --filter @syncpad/db db:migrate:dev",
    "db:migrate:prod": "pnpm --filter @syncpad/db db:migrate:prod",
    "db:seed:dev": "dotenv -e ./api/.env -- pnpm --filter @syncpad/api db:seed:dev",
    "db:migrate:test": "dotenv -e ./api/.env.test -- pnpm --filter @syncpad/db db:migrate:test",
    "db:bootstrap:test": "dotenv -e ./api/.env.test -- bash infra/local/ensure-test-db.sh",
    "permify:bootstrap:dev": "pnpm --filter api exec dotenv -e .env -- node ../infra/permify/bootstrap.js",
    "permify:bootstrap:prod": "pnpm --filter @syncpad/api exec node ../infra/permify/bootstrap.js",
    "permify:bootstrap:test": "pnpm --filter api exec dotenv -e .env.test -- node ../infra/permify/bootstrap.js",
    "infra:bootstrap:dev": "pnpm db:migrate:dev && pnpm permify:bootstrap:dev",
    "infra:bootstrap:prod": "pnpm db:migrate:prod && pnpm permify:bootstrap:prod",
    "infra:bootstrap:test": "pnpm db:bootstrap:test && pnpm db:migrate:test && pnpm permify:bootstrap:test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "msw"
    ]
  }
}
