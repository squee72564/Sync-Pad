{
  "name": "syncpad",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint:check": "turbo lint:check",
    "lint": "turbo lint",
    "check": "turbo check",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate": "pnpm --filter api db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css}": "biome check --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "msw"
    ]
  }
}
