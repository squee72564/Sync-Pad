{
  "name": "@syncpad/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc -w -p tsconfig.json --preserveWatchOutput",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --reporter=agent --silent=passed-only",
    "test:verbose": "vitest run --reporter=default",
    "test:watch": "vitest --reporter=default",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:check": "biome check .",
    "lint": "biome check . --write",
    "format:check": "biome format .",
    "format": "biome format . --write",
    "check": "pnpm lint:check && pnpm format:check && pnpm typecheck"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@syncpad/db": "workspace:*",
    "better-auth": "^1.6.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
