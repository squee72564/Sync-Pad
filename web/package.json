{
  "name": "@syncpad/web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts --reporter=agent --silent=passed-only",
    "test:verbose": "vitest run --config vitest.config.ts --reporter=default",
    "test:watch": "vitest --config vitest.config.ts --reporter=default",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:check": "biome check .",
    "lint": "biome check . --write",
    "format:check": "biome format .",
    "format": "biome format . --write",
    "check": "pnpm lint:check && pnpm format:check && pnpm typecheck"
  },
