{
  "name": "@syncpad/websocket",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "dotenv -e .env.test -- vitest run --config vitest.config.ts --reporter=agent --silent=passed-only",
    "test:verbose": "dotenv -e .env.test -- vitest run --config vitest.config.ts --reporter=default",
    "test:watch": "dotenv -e .env.test -- vitest --config vitest.config.ts --reporter=default",
    "test:coverage": "dotenv -e .env.test -- vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:check": "biome check .",
    "lint": "biome check . --write",
    "format:check": "biome format .",
    "format": "biome format . --write",
    "check": "pnpm lint:check && pnpm format:check && pnpm typecheck"
  },
  "dependencies": {
    "@hocuspocus/server": "^4.0.0",
    "@syncpad/auth": "workspace:*",
    "@syncpad/core": "workspace:*",
    "@syncpad/db": "workspace:*",
    "@syncpad/errors": "workspace:*",
    "@syncpad/permify": "workspace:*",
    "http-status-codes": "^2.3.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@syncpad/types": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
